# Optionnel : forcer une SECRET_KEY spécifique pour les tokens JWT
# Si absent, une clé est auto-générée et persistée dans la base de données
# SECRET_KEY=change-me-with-a-strong-random-key

# Optionnel : connexion bancaire via Enable Banking (enablebanking.com)
# Créez un compte sur enablebanking.com, récupérez votre App ID et générez une clé RSA
# Si absent, la fonctionnalité bank sync est désactivée dans l'app
# ENABLEBANKING_APP_ID=your-app-id
# ENABLEBANKING_PRIVATE_KEY_PATH=/backend/secrets/enablebanking.pem
